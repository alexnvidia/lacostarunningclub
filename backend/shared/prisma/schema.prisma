// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String               @id @default(uuid())
  email                    String               @unique
  passwordHash             String               @map("password_hash")
  firstName                String               @map("first_name")
  lastName                 String?              @map("last_name")
  phone                    String?              @map("phone")
  role                     Role                 @default(USER) @map("role")
  createdAt                DateTime             @default(now()) @map("created_at")
  active                   Boolean              @default(true) @map("active")
  lastLogin                DateTime?            @map("last_login")
  failedLoginAttempts      Int                  @default(0) @map("failed_login_attempts")
  lockoutUntil             DateTime?            @map("lockout_until")
  emailVerified            Boolean              @default(false) @map("email_verified")
  verificationToken        String?              @map("verification_token")
  verificationTokenExpires DateTime?            @map("verification_token_expires")
  resetPasswordToken       String?              @map("reset_password_token")
  resetPasswordExpires     DateTime?            @map("reset_password_expires")
  bmcEmail                 String?              @map("bmc_email")
  sessions                 Session[]
  addresses                Address[]
  productReviews           ProductReview[]
  orders                   Order[]
  carts                    Cart[]
  wishlists                Wishlist[]
  supportTickets           SupportTicket[]      @relation("UserTickets")
  assignedTickets          SupportTicket[]      @relation("AgentTickets")
  userAchievements         UserAchievement[]
  userTrainingPlans        UserTrainingPlan[]
  userPerformances         UserPerformance[]
  notifications            Notification[]
  messages                 Message[]            @relation("SenderMessages")
  statusChanges            OrderStatusHistory[]
  subscription             Subscription?
  rewards                  UserReward[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String    @map("user_id")
  tokenHash        String    @unique @map("token_hash")
  refreshTokenHash String?   @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  device           String?   @map("device")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime  @map("expires_at")
  isActive         Boolean   @default(true) @map("is_active")
  revokedAt        DateTime? @map("revoked_at")

  @@index([userId])
  @@index([isActive, expiresAt])
  @@index([tokenHash])
  @@map("sessions")
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  street     String
  city       String
  state      String?
  postalCode String   @map("postal_code")
  country    String
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

enum Role {
  USER
  ADMIN
  SUPPORT
  TRAINER
}

// --------------------------------------------------------
// PRODUCT CATALOG
// --------------------------------------------------------

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  sku         String   @unique
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  imageUrl    String?  @map("image_url")
  imageAlt    String?  @map("image_alt")
  imageAlt2   String?  @map("image_alt_2")
  imageTitle  String?  @map("image_title")
  imageBackground String? @map("image_background")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category   Category         @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  reviews    ProductReview[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  wishlist   Wishlist[]

  @@index([categoryId])
  @@index([sku])
  @@index([active])
  @@index([name]) // Búsqueda por nombre
  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  color     String?
  size      String?
  stock     Int     @default(0)
  sku       String  @unique

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model ProductReview {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  rating    Int      @default(5)
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([userId])
  @@map("product_reviews")
}

// --------------------------------------------------------
// ORDER & SALES
// --------------------------------------------------------

model Order {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  orderNumber       String      @unique @map("order_number")
  status            OrderStatus @default(PENDING)
  totalAmount       Decimal     @map("total_amount") @db.Decimal(10, 2)
  subtotalAmount    Decimal     @map("subtotal_amount") @db.Decimal(10, 2)
  shippingCost      Decimal     @map("shipping_cost") @db.Decimal(10, 2)
  shippingAddressId String      @map("shipping_address_id")
  trackingNumber    String?     @map("tracking_number")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user            User                 @relation(fields: [userId], references: [id])
  shippingAddress Address              @relation(fields: [shippingAddressId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]
  statusHistory   OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt]) // Importante para filtros de fecha en dashboard
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  paymentMethod String        @map("payment_method")
  transactionId String?       @map("transaction_id")
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([transactionId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Shipment {
  id                String    @id @default(uuid())
  orderId           String    @map("order_id")
  courier           String
  trackingNumber    String?   @map("tracking_number")
  status            String    @default("PREPARING")
  shippedAt         DateTime? @map("shipped_at")
  estimatedDelivery DateTime? @map("estimated_delivery")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([trackingNumber])
  @@map("shipments")
}

model OrderStatusHistory {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  previousStatus  String?  @map("previous_status") @db.VarChar(30)
  newStatus       String   @map("new_status") @db.VarChar(30)
  changedByUserId String?  @map("changed_by_user_id")
  comment         String?  @db.Text
  changedAt       DateTime @default(now()) @map("changed_at") @db.Timestamptz(3)

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId, changedAt(sort: Desc)])
  @@index([changedByUserId])
  @@map("order_status_history")
}

// --------------------------------------------------------
// SHOPPING CART & WISHLIST
// --------------------------------------------------------

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String @map("cart_id")
  productId String @map("product_id")
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// --------------------------------------------------------
// COMMUNICATION & SUPPORT
// --------------------------------------------------------

model SupportTicket {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  assignedTo String?      @map("assigned_to")
  subject    String
  status     TicketStatus @default(OPEN)
  priority   Priority     @default(MEDIUM)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user     User      @relation("UserTickets", fields: [userId], references: [id])
  agent    User?     @relation("AgentTickets", fields: [assignedTo], references: [id])
  messages Message[]

  @@index([userId])
  @@index([assignedTo])
  @@index([status])
  @@map("support_tickets")
}

model Message {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  senderId   String   @map("sender_id")
  content    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation("SenderMessages", fields: [senderId], references: [id])

  @@index([ticketId])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  read      Boolean  @default(false)
  type      String // 'ORDER', 'SYSTEM', 'PROMO'
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// --------------------------------------------------------
// PERFORMANCE & TRAINING
// --------------------------------------------------------

model UserPerformance {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  date            DateTime
  distanceKm      Float    @map("distance_km")
  durationMin     Int      @default(0) @map("duration_min")
  calories        Int?
  notes           String?

  // Race result fields (previously stored in notes metadata)
  raceName        String?  @map("race_name") @db.VarChar(200)
  time            String?  @db.VarChar(20)  // HH:MM:SS
  pace            String?  @db.VarChar(20)  // min/km
  location        String?  @db.VarChar(200)
  surfaceType     String?  @map("surface_type") @db.VarChar(20) // road, trail, track, mixed
  elevationGain   Int?     @map("elevation_gain")               // meters
  avgHeartRate    Int?     @map("avg_heart_rate")
  maxHeartRate    Int?     @map("max_heart_rate")
  temperature     Int?                                          // celsius
  attachmentUrl   String?  @map("attachment_url")
  isPublic        Boolean  @default(true) @map("is_public")

  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([isPublic])
  @@map("user_performances")
}


model WeeklyWorkout {
  id                String   @id @default(uuid())
  weekNumber        Int      @map("week_number")
  year              Int
  title             String   @db.VarChar(200)
  description       String   @db.Text
  workoutType       String?  @map("workout_type")       // technique, speed, endurance, recovery, strength, mixed
  estimatedDuration Int?     @map("estimated_duration") // minutes
  estimatedDistance Float?   @map("estimated_distance") // km
  difficultyLevel   String?  @map("difficulty_level")   // beginner, intermediate, advanced
  warmup            String?  @db.Text
  mainSet           String?  @map("main_set") @db.Text
  cooldown          String?  @db.Text
  weekStartDate     DateTime? @map("week_start_date") @db.Date
  weekEndDate       DateTime? @map("week_end_date") @db.Date
  isPublished       Boolean  @default(true) @map("is_published")
  publishedAt       DateTime @default(now()) @map("published_at")

  @@unique([weekNumber, year])
  @@index([year, weekNumber])
  @@index([isPublished])
  @@map("weekly_workouts")
}



model TrainingPlan {
  id            String   @id @default(uuid())
  name          String
  description   String?
  level         String
  durationWeeks Int      @map("duration_weeks")
  createdAt     DateTime @default(now()) @map("created_at")

  userPlans UserTrainingPlan[]

  @@map("training_plans")
}

model UserTrainingPlan {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  planId    String   @map("plan_id")
  startDate DateTime @map("start_date")
  status    String   @default("ACTIVE")
  progress  Int      @default(0)

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan TrainingPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("user_training_plans")
}

model Achievement {
  id          String  @id @default(uuid())
  name        String
  description String
  badgeUrl    String? @map("badge_url")
  criteria    Json

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// --------------------------------------------------------
// MEMBERSHIP & SUBSCRIPTIONS
// --------------------------------------------------------

model Subscription {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  status          String    @default("INACTIVE") // ACTIVE, INACTIVE, PAST_DUE
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  lastPaymentDate DateTime? @map("last_payment_date")
  provider        String    @default("buymeacoffee")
  externalId      String?   @map("external_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEvents BmcWebhookEvent[]

  @@map("subscriptions")
}

model UserReward {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  milestoneMonths Int       @map("milestone_months") // 3, 6, 9, 12
  unlockedAt      DateTime? @map("unlocked_at")
  isClaimed       Boolean   @default(false) @map("is_claimed")
  claimedAt       DateTime? @map("claimed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneMonths])
  @@map("user_rewards")
}

model BmcWebhookEvent {
  id             String        @id @default(uuid())
  eventId        String        @unique @map("event_id")    // ID externo de BMC — clave de idempotencia
  eventType      String        @map("event_type")          // ej. "membership.started"
  subscriptionId String?       @map("subscription_id")
  processedAt    DateTime      @default(now()) @map("processed_at")

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("bmc_webhook_events")
}
