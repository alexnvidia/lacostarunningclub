{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for La Costa Running Club",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node-dev src/index.ts",
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:auth": "jest tests/auth.middleware.test.ts",
    "test:gateway": "jest tests/gateway.test.ts",
    "test:proxy": "jest tests/proxy.test.ts"
  },
  "keywords": [
    "gateway",
    "microservices",
    "express-gateway"
  ],
  "author": "LCRC Tech Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.12.2",
    "base-x": "^5.0.1",
    "braces": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "got": "^14.6.0",
    "helmet": "^7.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.0",
    "micromatch": "^4.0.8",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "redis": "^5.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "validator": "^13.15.15",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
