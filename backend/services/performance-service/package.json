{
  "name": "performance-service",
  "version": "1.0.0",
  "description": "Performance Crew - Race results and training plans",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && mkdir -p dist/openapi && cp src/openapi/performance-service.yaml dist/openapi/",
    "dev": "tsx watch src/index.ts",
    "dev:mock": "USE_MOCK=true tsx watch --env-file=../../.env src/index.ts",
    "dev:oas": "USE_MOCK=false tsx watch --env-file=../../.env src/index.ts",
    "test": "jest",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "keywords": [
    "performance",
    "running",
    "microservice"
  ],
  "author": "LCRC Tech Team",
  "license": "MIT",
  "dependencies": {
    "@lcrc/shared": "file:../../shared",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.10",
    "pg": "^8.17.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@oas-tools/core": "^3.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "prisma": "^7.3.0",
    "supertest": "^6.3.4",
    "swagger-jsdoc": "^6.2.8",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "hono": "^4.11.10"
  }
}